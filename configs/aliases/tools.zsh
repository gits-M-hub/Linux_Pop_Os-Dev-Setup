# ==========================
# Tools Aliases
# ==========================
# Abreviaciones de herramientas populares para acceso rápido

# LazyGit
# lg = lazygit (abreviación de lazygit - interfaz de Git para terminal)
alias lg="lazygit"

# Yazi
# yz = yazi (abreviación de yazi - administrador de archivos moderno para terminal)
alias yz="yazi"

# Bat (cat mejorado)
# cat = batcat (sobrescribe el comando cat original con bat - tiene resaltado de sintaxis)
alias cat="batcat"
